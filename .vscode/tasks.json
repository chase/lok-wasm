{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make in podman",
            "type": "shell",
            "command": "cd libreoffice-core && make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                {
                    "base": "$gcc",
                    "fileLocation": "relative",
                    "pattern": {
                        "regexp": "^/home/emscripten/([^:]+):(\\d+):(\\d+):\\s+([^:]+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "message": 5,
                        "severity": 4
                    }
                }
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "${workspaceFolder}/in-podman",
                    "args": [
                        "-c"
                    ]
                }
            },
            "osx": {
                "problemMatcher": [
                    {
                        "base": "$gcc",
                        "fileLocation": "relative",
                        "pattern": {
                            "regexp": "^/([^:]+):(\\d+):(\\d+):\\s+([^:]+):\\s+(.*)$",
                            "file": 1,
                            "line": 2,
                            "column": 3,
                            "message": 5,
                            "severity": 4
                        }
                    }
                ],
                "options": {
                    "shell": {
                        "executable": "${workspaceFolder}/in-docker",
                        "args": [
                            "-c"
                        ]
                    }
                }
            }
        }
    ]
}